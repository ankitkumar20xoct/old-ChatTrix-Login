    /**
     * verifyTheFormTitle(sheetName)
     * ------------------------------------------------------------
     * Validates that:
     *  1. Browser tab title exists
     *  2. Title matches the expected `FormName` through Script
     *
     * @param {string} FormName - Expected title from Excel
     */
    static verifyTheFormTitle(FormName) {

        if(!FormName)
            throw new Error("ERROR: No 'FormName' found in Script — please check your Script.")
 
        getPageTitle()
        .should('not.eq','FormRenderer')
        .then((title) => {
 
            // 1. Normalize both texts before comparing
            const uiTitle = normalizeText(title);
            const expectedTitle = normalizeText(FormName)
 
            // 2. Final assertion
            softAssert(
                () => expect(uiTitle).to.eq(expectedTitle),
                `Page Title text match -> UI:"${uiTitle}" | EXPECTED: "${expectedTitle}"`
            )

        });

    }
    
    
    static verifyTheFormHeader(FormName) {

        if(!FormName)
            throw new Error("ERROR: No 'FormName' found in Script — please check your Script.")

        // STEP 1: HARD - ASSERT
        cy.get(this.Element.formHeader)
          .should('exist')
          .should('be.visible')
          .should('have.length', 1)

        // STEP 2: Validate header text ( SOFT ASSERT )
        cy.get(this.Element.formHeader)
          .invoke('text')
          .then((headerTxt) => {

            const uiHeaderTxt = normalizeText(headerTxt)
            const expectedHeaderTxt = normalizeText(FormName)

            softAssert(
                () => expect(uiHeaderTxt).to.eq(expectedHeaderTxt),
                `Form Header text match -> UI:"${uiHeaderTxt}" | EXPECTED: "${expectedHeaderTxt}"`
            )

          })

        //STEP 3: validate header CSS ( SOFT ASSERT )
        cy.get(this.Element.formHeader)
        .then((el) => {

            softAssert(
                () => expect(el).to.have.css('color', 'rgb(53, 53, 53)'),
                `Header Text color match`
            )

            softAssert(
                () => expect(el).to.have.css('font-size', '20px'),
                `Header Text font-size match`
            )

            softAssert(
                () => expect(el).to.have.css('font-family').match(/montserrat/i),
                `Header Text font-family match`
            )

        })
    }


