    static verifyTheCollapseAllButtonFunctionality() {


  clickOnElement(this.Element.collpaseAllIcon)

  cy.wait(5000)
 
  cy.get(this.Element.sectionPanel).as('sectionPanelContainer')
 
  cy.get('@sectionPanelContainer').then($sections => {
    const sectionCount = $sections.length
 
    for (let i = 0; i < sectionCount; i++) {
 
      cy.get('@sectionPanelContainer')
        .eq(i)
        .then($section => {
 
          //  aria-expanded should be false
          softAssert(
            () => expect($section.attr('aria-expanded')).to.eq('false'),
            `Section ${i + 1}: Section Panel Closed`
          )
 
          //  background color check
          softAssert(
            () => expect($section.css('background-color')).to.eq('rgb(99, 112, 133)'),
            `Section ${i + 1}: Section Panelbackground color should be Matched`
          )
 
          //  Collapse icon (must exist exactly once)
          const collapseIcon = $section.find(this.Element.sectionPanelCollapseIcon)
 
          softAssert(
            () => expect(collapseIcon.length).to.eq(1),
            `Section ${i + 1}: Exactly one collapse icon should exist`
          )
 
          softAssert(
            () => expect(collapseIcon).to.be.visible,
            `Section ${i + 1}: Collapse icon should be visible`
          )
 
          softAssert(
            () => expect(collapseIcon.css('color')).to.eq('rgb(255, 255, 255)'),
            `Section ${i + 1}: Collapse icon color should be white`
          )
 
          // Check icon should NOT exist
          softAssert(
            () => expect(
              $section.find('.fa.fa-lg.fa-check-circle.float-right').length
            ).to.eq(1),
            `Section ${i + 1}: unkown Check icon should exist`
          )

          softAssert(
            () => expect($section.find('.fa.fa-lg.fa-check-circle.float-right')).not.to.be.visible,
            `Section ${i + 1}: unkown Check icon should NOT visible`
          )
 
          //  Expand icon should NOT exist
          softAssert(
            () => expect(
              $section.find(this.Element.sectionPanelExpandIcon).length
            ).to.eq(0),
            `Section ${i + 1}: Expand icon should NOT exist`
          )
 
          //  Error icon should NOT exist
          softAssert(
            () => expect(
              $section.find(this.Element.sectionPanelErrorIcon).length
            ).to.eq(0),
            `Section ${i + 1}: Error icon should NOT exist`
          )

           //  Green icon should NOT exist
          softAssert(
            () => expect(
              $section.find(this.Element.sectionPanelGreenIcon).length
            ).to.eq(0),
            `Section ${i + 1}: Green icon should NOT exist`
          )
 
        })
    }
  })
}


